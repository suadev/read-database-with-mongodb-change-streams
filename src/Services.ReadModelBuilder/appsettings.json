{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "mongo": {
    "connectionString": "mongodb://localhost:27018/?replicaSet=rs0",
    "database": "orders",
    "resumeTokenRefreshIntervalHours": 1,
    "maxResumeTokenAgeHours": 3,
    "enableResumeTokenRefresh": true,
    "maxConsecutiveFailuresPerDocument": 15
  },
  "elastic": {
    "url": "http://localhost:9200",
    "username": null,
    "password": null,
    "apiKey": null,
    "orderDetailsIndexName": "order-details"
  },
  "snapshot": {
    "batchSize": 100
  },
  "services": {
    "customer": {
      "baseUrl": "http://localhost:5101"
    },
    "product": {
      "baseUrl": "http://localhost:5102"
    }
  }
}
