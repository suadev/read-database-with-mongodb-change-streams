      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/Services.ReadModelBuilder/bin/Debug/net10.0/Services.ReadModelBuilder.dll",
      "cwd": "${workspaceFolder}/src/Services.ReadModelBuilder",
      "args": [],
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development"
      },
      "console": "internalConsole",
      "stopAtEntry": false,
      "suppressJITOptimizations": true,
      "justMyCode": false,
      "requireExactSource": false,
      "enableStepFiltering": true,
      "sourceLinkOptions": {
